<%- include('partials/header') %>

<div class="container">
    <h1>Gerenciamento de Produtos</h1>
     // <%= %> = renderiza o conteudo
    <h2><%= produtoEditar ? 'Alterar Produto' : 'Cadastrar Novo' %></h2>

    // action = para onde o formulário vai enviar os dados
    <form action="<%= produtoEditar ? '/produtos/editar/' + produtoEditar.id : '/produtos/adicionar' %>" method="POST">
        <input type="text" name="nome" value="<%= produtoEditar ? produtoEditar.nome : '' %>" placeholder="Nome do produto" required><br><br>
        <input type="number" name="preco" step="0.01" value="<%= produtoEditar ? produtoEditar.preco : '' %>" placeholder="Valor do produto" required><br><br>
        <button type="submit"><%= produtoEditar ? 'Confirmar Alteração' : 'Cadastrar' %></button>
    </form>
    
    <hr>
    
    <h2>Produtos Cadastrados</h2>
    
    <% if(produtos.length === 0) { %>
        <p>Nenhum produto foi cadastrado ainda.</p>
    <% } else { %>
        <ul>
             // forEach = loop que percorre cada produto
            <% produtos.forEach(item => { %>
                <li>
                    <strong><%= item.nome %></strong> - Valor: R$ <%= parseFloat(item.preco).toFixed(2) %>
                    <a href="/produtos/excluir/<%= item.id %>"> [Remover]</a>
                    <a href="/produtos/editar/<%= item.id %>"> [Alterar]</a>
                </li>
            <% }) %>
        </ul>
    <% } %>
</div>

<%- include('partials/footer') %>
